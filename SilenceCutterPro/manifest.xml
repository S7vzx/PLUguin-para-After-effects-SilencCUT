<?xml version="1.0" encoding="UTF-8"?>
<Extension ManifestVersion="7" Version="2.0.0" ExtensionBundleId="com.professional.silencecutterpro" ExtensionBundleVersion="2.0.0" ExtensionBundleName="Silence Cutter Pro" xmlns="http://ns.adobe.com/air/extension/manifest/v7">
    <ExtensionPoint Id="PPROPanel">
        <Menu>
            <MenuItem Id="SilenceCutterProMenu" Label="Silence Cutter Pro" Enabled="true" Menu=""/>
        </Menu>
        <Geometry>
            <Size>
                <Height>600</Height>
                <Width>500</Width>
            </Size>
        </Geometry>
        <Locale>
            <String Id="en_US" Name="Silence Cutter Pro"/>
        </Locale>
    </ExtensionPoint>
    <ExecutionEnvironment>
        <HostList>
            <Host Name="PPRO" Version="13.0"/>
        </HostList>
        <LocaleList>
            <Locale Code="en_US"/>
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="9.0"/>
        </RequiredRuntimeList>
    </ExecutionEnvironment>
    <DispatchInfoList>
        <DispatchInfo Id="SilenceCutterProUI" Priority="1" Extensions="html,js,css">
            <Plugins>
                <Plugin Type="HTML" Path="index.html" Weight="1.0"/>
            </Plugins>
            <LocaleList>
                <Locale Code="en_US"/>
            </LocaleList>
            <RequestRuntime Access="all" Name="Node" Version="14.0.0"/>
        </DispatchInfo>
    </DispatchInfo>
    <Resources>
        <MainPath>./index.html</MainPath>
        <ScriptPath>./js/
        </ScriptPath>
        <ResourcePath>./resources/
        </ResourcePath>
        <LocalePath>./locales/
        </LocalePath>
    </Resources>
    <Data>
        <KeyValuePairs>
            <Key Name="DeveloperName" Value="Professional Video Tools"/>
            <Key Name="DeveloperURL" Value="https://professionalvideotools.com"/>
            <Key Name="Description" Value="Premiere Pro Automation Suite with AI-powered features"/>
        </KeyValuePairs>
    </Data>
</Extension>